<?xml version="1.0" encoding="UTF-8"?>
<project version="1">
    <root name="." />
    <builddir>build</builddir>
    <analyze-all-vs-configs>true</analyze-all-vs-configs>
    <check-headers>true</check-headers>
    <check-unused-templates>true</check-unused-templates>
    <max-ctu-depth>2</max-ctu-depth>
    <max-template-recursion>100</max-template-recursion>
    
    <!-- Include paths for Flutter Windows -->
    <includedir>
        <dir name="windows/flutter/ephemeral" />
        <dir name="windows/runner" />
    </includedir>
    
    <!-- Suppress all warnings for Flutter-generated code -->
    <suppressions>
        <suppression>missingIncludeSystem</suppression>
        <suppression>missingInclude</suppression>
        <suppression>unmatchedSuppression</suppression>
        <suppression>*:windows/runner/*</suppression>
        <suppression>*:windows/flutter/*</suppression>
        <suppression>*:macos/*</suppression>
        <suppression>*:linux/*</suppression>
        <suppression>*:ios/*</suppression>
        <suppression>*:android/*</suppression>
    </suppressions>
    
    <!-- Exclude generated and third-party code -->
    <exclude>
        <path name="build/" />
        <path name=".dart_tool/" />
        <path name="windows/" />
        <path name="macos/" />
        <path name="linux/" />
        <path name="ios/" />
        <path name="android/" />
    </exclude>
</project>
